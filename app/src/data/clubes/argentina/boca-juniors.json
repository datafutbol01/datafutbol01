  "historia": [
    {
      "ano": "1905",
      "hito": "Fundación en la Plaza Solís",
      "desc": "El 3 de abril de 1905, un grupo de adolescentes hijos de inmigrantes italianos se reunió en un banco de la Plaza Solís, en el barrio de La Boca, para fundar el Club Atlético Boca Juniors. Inspirados por los buques que amarraban en el puerto, adoptaron los colores azul y oro tras observar la bandera de un barco sueco."
    },
    {
      "ano": "1925",
      "hito": "La Gira Europea",
      "desc": "Boca Juniors se convirtió en el primer equipo argentino en realizar una extensa gira de competición por Europa. Disputaron 19 partidos contra importantes equipos de España, Alemania y Francia, obteniendo 15 victorias, lo que les valió el reconocimiento oficial de Campeones de Honor."
    },
    {
      "ano": "1977-1978",
      "hito": "El bicampeonato de América y la Intercontinental",
      "desc": "Bajo la conducción técnica de Juan Carlos Lorenzo, el club conformó un bloque defensivo histórico que le permitió obtener sus dos primeras Copas Libertadores de América de forma consecutiva. Además, conquistaron su primera Copa Intercontinental al vencer al Borussia Mönchengladbach de Alemania en 1978."
    },
    {
      "ano": "2000-2003",
      "hito": "La época dorada de Carlos Bianchi",
      "desc": "Al mando del entrenador Carlos Bianchi y con el talento en el campo de Juan Román Riquelme y Martín Palermo, Boca Juniors gozó del período más exitoso de su historia. Ganaron tres Copas Libertadores (2000, 2001, 2003) y dos Copas Intercontinentales, derrotando a poderosos europeos como el Real Madrid y el AC Milan."
    }
  ],
