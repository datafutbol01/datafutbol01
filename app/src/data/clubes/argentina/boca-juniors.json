  "idolos": [
    {
      "nombre": "Juan Román Riquelme",
      "pos": "Enganche",
      "apodo": "El Último Diez / Román",
      "epoca": "1996-2014",
      "desc": "Símbolo innegable de la época dorada boquense. Con su visión periférica y pegada magistral, guio al club hacia la conquista de tres Copas Libertadores y la histórica Copa Intercontinental ante el Real Madrid en el año 2000."
    },
    {
      "nombre": "Martín Palermo",
      "pos": "Delantero",
      "apodo": "El Titán / El Loco",
      "epoca": "1997-2011",
      "desc": "Máximo artillero histórico de la institución. Delantero de área implacable, forjó su leyenda a base de goles heroicos y un optimismo inquebrantable que lo consolidó como el gran definidor del ciclo de Carlos Bianchi."
    },
    {
      "nombre": "Diego Armando Maradona",
      "pos": "Enganche",
      "apodo": "Pelusa / D10S",
      "epoca": "1981-1997",
      "desc": "Aunque su paso se dividió en dos etapas, su magia inmortalizó la obtención del Campeonato Metropolitano de 1981. Su idilio con la grada transformó su figura en una religión ineludible para el hincha xeneize."
    },
    {
      "nombre": "Guillermo Barros Schelotto",
      "pos": "Delantero / Extremo",
      "apodo": "El Mellizo",
      "epoca": "1997-2007",
      "desc": "Atacante desequilibrante y provocador, emblema de la rebeldía boquense. Su inteligencia táctica y su carácter indomable lo erigieron como uno de los máximos ganadores de títulos en la historia del club."
    },
    {
      "nombre": "Ángel Clemente Rojas",
      "pos": "Delantero",
      "apodo": "Rojitas",
      "epoca": "1963-1971",
      "desc": "Talento puro y desfachatado que deslumbró a la afición en la década del sesenta. Su quiebre de cintura y habilidad en espacios reducidos lo convirtieron en el primer gran ídolo moderno de La Bombonera."
    }
  ],
